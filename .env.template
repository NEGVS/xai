# .env配置文件
# 复制此文件为.env并填入实际的API密钥

# ============================================
# AI服务配置
# ============================================

# OpenAI
OPENAI_sss=ads-sewproj-REPLACE_WITH_YOUR_KEY
OPENAI_MODEL=gpt-4

# Anthropic (Claude) - 推荐使用
ANTHROPIC_sss=ads-ant-REPLACE_WITH_YOUR_KEY
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ============================================
# 数据源API配置
# ============================================

# NewsAPI (可选，用于获取新闻)
NEWS_sss=REPLACE_WITH_YOUR_KEY

# Alpha Vantage (可选，股票数据备用源)
ALPHA_VANTAGE_sss=REPLACE_WITH_YOUR_KEY

# ============================================
# 数据库配置
# ============================================

# PostgreSQL
DATABASE_URL=postgresql://admin:password@localhost:5432/stock_analysis

# Redis
REDIS_URL=redis://localhost:6379

# ============================================
# 应用配置
# ============================================

# 环境
ENVIRONMENT=development
DEBUG=true

# 日志
LOG_LEVEL=INFO

# API配置
API_HOST=0.0.0.0
API_PORT=8000
